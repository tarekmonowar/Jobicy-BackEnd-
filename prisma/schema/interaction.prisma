// User ↔ job interactions: saved jobs, applications, and alerts.
model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  appliedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model Alert {
  id         String         @id @default(cuid())
  userId     String
  keywords   String[]
  skills     String[]
  location   String?
  jobType    JobType?
  salaryMin  Int?
  frequency  AlertFrequency @default(INSTANT)
  isActive   Boolean        @default(true)
  lastSentAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive, frequency])
}
